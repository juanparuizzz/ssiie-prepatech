doctype html
html(lang="es")
  head
    meta(charset="UTF-8")
    title= title
    link(rel="stylesheet", href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css")
    style.
      body { background-color: white; font-family: 'Segoe UI', sans-serif; }
      .boleta-header { border-bottom: 3px solid #0d6efd; padding-bottom: 10px; margin-bottom: 30px; }
      .logo-placeholder { font-size: 40px; font-weight: bold; color: #0d6efd; }
      .table thead { background-color: #f8f9fa !important; color: black; }
      @media print {
        .no-print { display: none; }
        body { padding: 0; }
        .btn-print { display: none; }
      }
  body
    .container.mt-5
      .text-end.mb-3
        button.btn.btn-primary.btn-print(onclick="window.print()") 🖨️ Generar Boleta de Preparatoria

      .boleta-header.row.align-items-center
        .col-2.text-center
          .logo-placeholder 🏫
        .col-7
          h2.mb-0 Preparatoria Tech - del Norte 
          p.text-muted.mb-0 Sistema de Control Escolar
          p.small.mb-0 Certificado Parcial de Calificaciones
        .col-3.text-end
          h4.text-primary Ciclo #{new Date().getFullYear()}
      
      .row.mb-4
        .col-6
          p.mb-1: strong Alumno: 
            span.text-uppercase= alumno.nombre
          p.mb-1: strong Grado y Grupo: 
            span #{alumno.grado}° Semestre - Grupo "#{alumno.grupo}"
        .col-6.text-end
          p.mb-1: strong Fecha de Emisión: 
            span= new Date().toLocaleDateString()

      table.table.table-bordered.mt-4
        thead
          tr
            th(style="width: 70%") Asignatura 
            th.text-center Calificación
            th.text-center Resultado
        tbody
          each nota in calificaciones
            tr
              td= nota.nombre_materia
              td.text-center.fw-bold= nota.calificacion
              td.text-center
                if nota.calificacion >= 6
                  span.text-success Aprobado
                else
                  span.text-danger Reprobado
      
      .row.mt-5
        .col-6.text-center.mt-5
          .border-top.pt-2(style="width: 200px; margin: 0 auto;") Firma del Tutor
        .col-6.text-center.mt-5
          .border-top.pt-2(style="width: 200px; margin: 0 auto;") Dirección Académica

    script.
      // Opción para que se abra el panel de impresión solo
      // window.onload = () => { window.print(); }